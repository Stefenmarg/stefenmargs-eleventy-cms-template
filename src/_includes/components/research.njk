<section class="relative px-10 py-12 overflow-hidden" id="research">
  <!-- Header -->
  <p class="text-center text-xs uppercase tracking-widest text-gray-400 mb-2">Research</p>
  <p class="text-center text-3xl md:text-5xl font-bold leading-tight mb-2">Research areas</p>
  <p class="text-center text-base text-gray-500 mb-10">The core topics our team investigates</p>

  <!-- Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-4xl mx-auto">

    {% for entry in research.items %}

      <div class="bg-white border border-gray-200 rounded-xl p-6">
        <div class="w-10 h-10 rounded-lg bg-gray-100 flex items-center justify-center mb-4">
          <img alt="Icon related to the {{entry.name}} research area" class="rounded-lg" src="{{ entry.icon }}">  
        </div>
        <p class="text-sm font-semibold text-gray-900 mb-2"> {{ entry.name }} </p>
        <p class="text-sm text-gray-500 leading-relaxed"> {{ entry.desc }} </p>
      </div>

    {% endfor %}

  </div>
</section>